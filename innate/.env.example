# n8n Judge — environment template. Copy to .env (git-ignored) and fill in.

# --- Database (Prisma + pg-boss share this Postgres) -----------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/judge?schema=public"

# --- Auth (interim email/password before Login-with-Scaler SSO) ------------
AUTH_SECRET="change-me-openssl-rand-base64-32"

# --- Claude API ------------------------------------------------------------
ANTHROPIC_API_KEY=""
# Model tiers (swappable). Sonnet for grading and authoring; cheap tier for Ask-AI.
JUDGE_GRADING_MODEL="claude-sonnet-5"
JUDGE_AUTHORING_MODEL="claude-sonnet-5"
JUDGE_ASKAI_MODEL="claude-haiku-4-5-20251001"

# --- Queue -----------------------------------------------------------------
# pg-boss now, sqs later. pg-boss reuses DATABASE_URL.
QUEUE_DRIVER="pgboss"
GRADING_CONCURRENCY="10"

# --- Voice / mascot (M6, feature-flagged) ----------------------------------
FEATURE_VOICE="false"
DEEPGRAM_API_KEY=""
# S3 (or local dir in dev) for pre-rendered voice clips
VOICE_S3_BUCKET=""
